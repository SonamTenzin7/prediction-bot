# Polygon node (get free key from Alchemy or Infura)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/pWkxrZhxzBbQZWp5fBecX

# Hot wallet — minimum USDC balance only, NEVER main wallet
PRIVATE_KEY=your_private_key_here

# Polymarket CLOB API base
POLYMARKET_API_BASE=https://clob.polymarket.com

# The Graph — Polymarket subgraph endpoint
POLYMARKET_SUBGRAPH=https://api.thegraph.com/subgraphs/name/polymarket/polymarket-matic

# Binance WebSocket
BINANCE_WS=wss://stream.binance.com:9443/ws/btcusdt@trade

# Copy engine settings
MIN_WIN_RATE=0.80           # 80% minimum to qualify as copy target
MIN_TRADES_TO_QUALIFY=20    # Must have traded >= 20 BTC markets
RESCAN_INTERVAL_MINUTES=60  # Re-rank wallets every hour

# Risk
MAX_POSITION_PCT=0.05       # 5% of balance per trade
DAILY_LOSS_LIMIT_PCT=0.15   # Halt trading if down 15% on the day

# Mode (paper or live — bot reads this at startup)
TRADING_MODE=paper

# Telegram bot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_personal_chat_id

# Alert + entry timing
ENTRY_LEAD_SECONDS=15       # enter this many seconds before window opens
SCAN_LEAD_SECONDS=45        # start scanning this many seconds before window
EV_MIN_THRESHOLD=0.05       # minimum EV per $1 to fire a trade
KELLY_FRACTION=0.5          # 0.5 = half-Kelly, 1.0 = full Kelly

# Auto-trade toggle (even in live mode you can disable auto-trade)
AUTO_TRADE_ENABLED=true
ALERT_ONLY_MODE=false       # if true: sends Telegram alert but does NOT place order
